# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/vendflow"

# Auth (NextAuth v5)
# Gere com: openssl rand -base64 32
AUTH_SECRET="seu-secret-aqui-min-32-chars"
AUTH_URL="http://localhost:3001"

# Stripe (assinatura do SaaS)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Mercado Pago (pagamentos nas lojas)
MERCADOPAGO_ACCESS_TOKEN=""
# Webhook secret — configurar em: MP Dashboard > Webhooks > Sua aplicação
# Gere com: openssl rand -hex 32
MP_WEBHOOK_SECRET=""

# JWT secret para autenticação de clientes na loja pública
# Gere com: openssl rand -hex 32
CUSTOMER_JWT_SECRET=""

# OAuth do Mercado Pago (para lojistas conectarem suas contas)
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""

# Cloudflare R2 (storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="vendflow"
R2_PUBLIC_URL=""
