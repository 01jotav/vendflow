# ============================================================================
# Vendflow — Environment Variables
# Copie este arquivo para .env (raiz) e para apps/app/.env.local + apps/store/.env.local
# ============================================================================

# ---- Database (Supabase PostgreSQL) ----------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/vendflow"

# ---- Auth (NextAuth v5) -----------------------------------------------------
# Gere com: openssl rand -base64 32
AUTH_SECRET="seu-secret-aqui-min-32-chars"
AUTH_URL="http://localhost:3001"
# URL pública do app (usada para redirects do Stripe em produção)
NEXT_PUBLIC_APP_URL="https://vendflow-app.vercel.app"

# ---- Stripe (assinatura do SaaS — billing dos lojistas) --------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price ID do plano PRO (criar no Stripe Dashboard > Products)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=""

# ---- Mercado Pago (pagamentos nas lojas) -----------------------------------
MERCADOPAGO_ACCESS_TOKEN=""
# Webhook secret — configurar em: MP Dashboard > Webhooks > Sua aplicação
# Gere com: openssl rand -hex 32
MP_WEBHOOK_SECRET=""

# OAuth do Mercado Pago (para lojistas conectarem suas contas)
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""

# ---- JWT do cliente final (loja pública) ------------------------------------
# Gere com: openssl rand -hex 32
CUSTOMER_JWT_SECRET=""

# ============================================================================
# Cloudflare R2 — Storage de Imagens (produtos + logos)
# ============================================================================
# Passo a passo:
# 1. Acesse https://dash.cloudflare.com/ → R2 Object Storage
# 2. Crie um bucket (ex: "vendflow") — NÃO precisa ser público na hora da criação
# 3. Em "Manage R2 API Tokens" crie um token com permissão "Object Read & Write"
#    — copie Access Key ID e Secret Access Key (só aparecem uma vez)
# 4. Em Account Home, pegue o Account ID (32 chars hex)
# 5. No bucket criado, vá em "Settings" → "Public access":
#    - Opção A (simples): conecte um Custom Domain (ex: cdn.vendflow.com)
#    - Opção B (dev): habilite "R2.dev subdomain" (URL tipo pub-XXXX.r2.dev)
#    Use essa URL (sem barra no fim) como R2_PUBLIC_URL
# ----------------------------------------------------------------------------
# Token de API R2 (Object Read & Write)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# Endpoint S3-compatível do R2 (bucket settings → S3 API)
# Formato: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=""
# Nome do bucket criado no R2
R2_BUCKET_NAME="vendflow-images"
# URL pública de leitura (custom domain OU r2.dev subdomain) — SEM barra no fim
# Exemplos:
#   R2_PUBLIC_URL="https://cdn.vendflow.com"
#   R2_PUBLIC_URL="https://pub-abc123def456.r2.dev"
R2_PUBLIC_URL=""
